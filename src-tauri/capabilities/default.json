{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "default",
  "description": "Capability granted to the main Dev Core Tools window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-read",
    "fs:allow-write",
    "shell:allow-open",
    "process:allow-exit",
    "process:allow-restart",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download-and-install"
  ]
}
